﻿﻿﻿﻿﻿﻿﻿<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="440" d:DesignWidth="630">
    <Grid x:Name="Root">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="玩几场后停止"  Margin="3,5,3,1" />
                    <CheckBox x:Name="StopAfterXGamesCheckBox" Grid.Row="0" Grid.Column="1" Margin="3"
                              IsChecked="{Binding StopAfterXGames, Mode=TwoWay}" />
                    <Label Grid.Row="0" Grid.Column="3" Content="场"  Margin="3,5,3,1" />
                    <TextBox Name="StopGameCountTextBox" Grid.Row="0" Grid.Column="2" Margin="3"
                             Text="{Binding StopGameCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                    <Label Grid.Row="1" Grid.Column="0" Content="胜几场后停止"  Margin="3,5,3,1" />
                    <CheckBox x:Name="StopAfterXWinsCheckBox" Grid.Row="1" Grid.Column="1" Margin="3"
                              IsChecked="{Binding StopAfterXWins, Mode=TwoWay}" />
                    <Label Grid.Row="1" Grid.Column="3" Content="场"  Margin="3,5,3,1" />
                    <TextBox Name="StopWinCountTextBox" Grid.Row="1" Grid.Column="2" Margin="3"
                             Text="{Binding StopWinCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                    <Label Grid.Row="2" Grid.Column="0" Content="败几场后停止"  Margin="3,5,3,1" />
                    <CheckBox x:Name="StopAfterXLossesCheckBox" Grid.Row="2" Grid.Column="1" Margin="3"
                              IsChecked="{Binding StopAfterXLosses, Mode=TwoWay}" />
                    <Label Grid.Row="2" Grid.Column="3" Content="场"  Margin="3,5,3,1" />
                    <TextBox Name="StopLossCountTextBox" Grid.Row="2" Grid.Column="2" Margin="3"
                             Text="{Binding StopLossCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                    <Label Grid.Row="3" Grid.Column="0" Content="游戏时长自动投降"  Margin="3,5,3,1" />
                    <CheckBox x:Name="ConcedeAfterXMinutesCheckBox" Grid.Row="3" Grid.Column="1" Margin="3"
                              IsChecked="{Binding ConcedeAfterXMinutes, Mode=TwoWay}" />
                    <Label Grid.Row="3" Grid.Column="3" Content="分钟"  Margin="3,5,3,1" />
                    <TextBox Name="ConcedeMinutesCountTextBox" Grid.Row="3" Grid.Column="2" Margin="3"
                             Text="{Binding ConcedeMinutesCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                </Grid>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="当前胜场: "  Margin="3,5,3,1" />
                    <TextBox Name="WinsTextBox" Grid.Row="0" Grid.Column="1" Margin="3" IsReadOnly="True"
                             Text="{Binding Wins, Mode=OneWay}" />

                    <Label Grid.Row="1" Grid.Column="0" Content="当前败场: "  Margin="3,5,3,1" />
                    <TextBox Name="LossesTextBox" Grid.Row="1" Grid.Column="1" Margin="3" IsReadOnly="True"
                             Text="{Binding Losses, Mode=OneWay}" />

                </Grid>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="动态打脸惩罚" Margin="3,5,3,1" />
                    <CheckBox x:Name="DynamicFacePenaltyEnabledCheckBox" Grid.Row="0" Grid.Column="1" Margin="3"
                              IsChecked="{Binding DynamicFacePenaltyEnabled, Mode=TwoWay}" />

                    <Label Grid.Row="1" Grid.Column="0" Content="打脸切换时间" Margin="3,5,3,1" />
                    <TextBox Name="DynamicFacePenaltyMinutesTextBox" Grid.Row="1" Grid.Column="1" Margin="3"
                             Text="{Binding DynamicFacePenaltyMinutes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                    <Label Grid.Row="1" Grid.Column="2" Content="分钟" Margin="3,5,3,1" />

                    <Label Grid.Row="2" Grid.Column="0" Content="时间前打脸惩罚" Margin="3,5,3,1" />
                    <TextBox Name="FacePenaltyBeforeTimeTextBox" Grid.Row="2" Grid.Column="1" Margin="3"
                             Text="{Binding FacePenaltyBeforeTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                    <Label Grid.Row="3" Grid.Column="0" Content="时间后打脸惩罚" Margin="3,5,3,1" />
                    <TextBox Name="FacePenaltyAfterTimeTextBox" Grid.Row="3" Grid.Column="1" Margin="3"
                             Text="{Binding FacePenaltyAfterTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                </Grid>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Content="全部重置" Name="ResetButton" Grid.Row="0" Grid.Column="0" Margin="3"
                            Command="{Binding ResetCommand}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
